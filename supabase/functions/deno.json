{
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["esnext", "dom", "deno.ns"],
    "types": ["jsr:@supabase/functions-js/edge-runtime"]
  },
  "fmt": {
    "useTabs": false,
    "indentWidth": 2,
    "lineWidth": 100
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-explicit-any", "require-await"]
    }
  },
  "imports": {
    "npm:@supabase/supabase-js": "npm:@supabase/supabase-js",
    "npm:stripe": "npm:stripe"
  }
}
