{
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["esnext", "dom", "deno.ns"],
    "types": ["jsr:@supabase/functions-js/edge-runtime"]
  },
  "fmt": {
    "useTabs": false,
    "indentWidth": 2,
    "lineWidth": 100
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-explicit-any", "require-await"]
    }
  },
  "imports": {
    "npm:@supabase/supabase-js": "npm:@supabase/supabase-js@2.57.4",
    "npm:@supabase/supabase-js@2": "npm:@supabase/supabase-js@2.57.4",
    "npm:@supabase/supabase-js@2.57.4": "npm:@supabase/supabase-js@2.57.4",
    "npm:stripe": "npm:stripe@20.0.0",
    "npm:stripe@20.0.0": "npm:stripe@20.0.0"
  }
}
